LOVABLE_INGEST_URL=
LOVABLE_SCRAPER_INGEST_TOKEN=
SCRAPER_ENTRYPOINT=job_scraper.main:scrape_all_sources
SCRAPER_BATCH_SIZE=100
SOURCE_FAILURE_POLICY=continue
GLOBAL_JOB_CATEGORIES=Software Engineering,Backend Development,Frontend Development,Full Stack Development,Data Analytics,Business Analysis,Data Engineering,DevOps,Cloud Engineering,QA Automation,Product Management,Cybersecurity,AI Engineering,Machine Learning,Salesforce,Workday,IT Support
GLOBAL_JOB_LOCATIONS=United States,Remote,Texas,California,New York,New Jersey,Illinois,Georgia,Florida,Washington
JOB_SOURCE_URLS=https://remoteok.com/remote-dev-jobs,https://weworkremotely.com/categories/remote-programming-jobs,https://himalayas.app/jobs/developer,https://builtin.com/jobs/remote/dev-engineering
ENABLE_BROWSER_FETCHER=false
BROWSER_FETCHER_TIMEOUT_SECONDS=30
GOOGLE_JOBS_PROVIDER=disabled
SERPAPI_API_KEY=
SCRAPERAPI_API_KEY=
LINKEDIN_PROVIDER=disabled
INDEED_PROVIDER=disabled
GLASSDOOR_PROVIDER=disabled
ZIPRECRUITER_PROVIDER=disabled
GOOGLE_JOBS_MAX_QUERIES_PER_RUN=5
GOOGLE_JOBS_MAX_RESULTS_PER_QUERY=20

